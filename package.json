{
  "name": "tea-guia-inteligente",
  "version": "0.1.0",
  "private": true,
  "description": "TEA Guia Inteligente — aplicativo educacional e informativo para famílias, cuidadores e profissionais sobre o Transtorno do Espectro Autista.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
