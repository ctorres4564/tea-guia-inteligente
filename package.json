    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:firebase": "node firebase/test/firebase-admin-smoke.mjs",
    "test:rules": "node firebase/test/firestore-rules.test.mjs",
    "test:storage": "node firebase/test/storage-rules.test.mjs",
    "firebase:emulators": "firebase emulators:start",
    "firebase:seed": "node firebase/seed/seed.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@hookform/resolvers": "3.9.0",
    "@vercel/functions": "^3.7.5",
    "clsx": "2.1.1",
    "firebase": "10.13.2",
    "firebase-admin": "12.4.0",
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.53.0",
    "server-only": "0.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.4.8",
    "@testing-library/react": "16.0.0",
    "@types/node": "20.14.15",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.1",
    "@vitest/coverage-v8": "2.0.5",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.15",
    "jsdom": "24.1.1",
    "postcss": "8.4.41",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.6",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
