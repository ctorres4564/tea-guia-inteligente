rules_version = '2';

// ============================================================================
// TEA Guia Inteligente — Regras de Segurança do Cloud Firestore
//
// Estratégia de controle por papel (role):
// Nesta fase optamos por LER o papel do usuário a partir do próprio documento
// `profiles/{uid}` (campo `role`), em vez de usar Firebase Auth Custom Claims.
// Motivo (ver docs/decisions/ADR-002-auth-strategy.md):
//   - Custom Claims exigem um passo administrativo adicional (Admin SDK) e
//     revogação/atualização do ID Token para refletir mudanças de papel;
//   - Para o MVP, ler `profiles/{uid}.role` é mais simples e suficiente,
//     ao custo de uma leitura extra por regra (aceitável neste volume).
//   - Migração futura para Custom Claims é recomendada quando o número de
//     leituras de regra impactar performance/custo (documentado no ROADMAP).
//
// Princípio: nenhuma regra depende exclusivamente da interface. Toda
// permissão sensível é validada aqui, no servidor de regras do Firestore.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && userProfile().role == role;
    }

    function isAdmin() {
      return hasRole('administrator');
    }

    function isReviewer() {
      return hasRole('reviewer') || isAdmin();
    }

    function isContentEditor() {
      return hasRole('professional') || hasRole('reviewer') || isAdmin();
    }

    function isActiveAccount() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && userProfile().status == 'active';
    }

    // ------------------------------------------------------------------
    // profiles/{userId}
    // ------------------------------------------------------------------
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Criação: apenas o próprio usuário, e somente com papel/status padrão.
      // Isso impede que alguém se autopromova a administrador no cadastro.
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'family'
        && request.resource.data.status == 'active';

      // Atualização pelo próprio usuário: apenas campos de perfil pessoal.
      // `role` e `status` nunca podem ser alterados pelo próprio usuário.
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
        );

      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // categories/{categoryId}
    // ------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if resource.data.status == 'published' || isContentEditor();
      allow create, update: if isContentEditor();
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // knowledgeItems/{itemId}
    // ------------------------------------------------------------------
    match /knowledgeItems/{itemId} {
      // Conteúdo publicado é público; rascunhos/em revisão só para papéis autorizados.
      allow read: if (resource.data.reviewStatus == 'published' && resource.data.deletedAt == null)
        || isContentEditor();

      allow create: if isContentEditor()
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.deletedAt == null;

      // Edição de conteúdo por profissionais/revisores/admin, com duas
      // restrições adicionais (Fase 2):
      //  1. Transições de reviewStatus para 'approved', 'published' ou
      //     'rejected' são decisões de revisão e exigem isReviewer(). Autores
      //     (professional) podem livremente mover entre 'draft' e
      //     'in_review' (submissão para revisão) sem precisar de um revisor.
      //  2. Exclusão lógica (definir deletedAt) é restrita a administradores,
      //     assim como a exclusão física — "somente administradores possam
      //     excluir conteúdos".
      allow update: if isContentEditor()
        && (
          request.resource.data.deletedAt == resource.data.deletedAt || isAdmin()
        )
        && (
          !(request.resource.data.reviewStatus in ['approved', 'published', 'rejected'])
          || isReviewer()
        );

      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // knowledgeSources/{sourceId}
    // ------------------------------------------------------------------
    match /knowledgeSources/{sourceId} {
      allow read: if true;
      allow create, update: if isContentEditor();
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // favorites/{userId}/items/{favoriteId}
    // Estrutura documentada nesta fase; interface implementada em fase futura.
    // ------------------------------------------------------------------
    match /favorites/{userId}/items/{favoriteId} {
      allow read, write: if isOwner(userId) && isActiveAccount();
    }

    // ------------------------------------------------------------------
    // history/{userId}/items/{historyId}
    // Estrutura documentada nesta fase; recurso implementado em fase futura.
    // ------------------------------------------------------------------
    match /history/{userId}/items/{historyId} {
      allow read, write: if isOwner(userId) && isActiveAccount();
    }

    // Bloqueio padrão: qualquer coleção não listada explicitamente é negada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
