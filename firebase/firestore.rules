rules_version = '2';

// ============================================================================
// TEA Guia Inteligente — Regras de Segurança do Cloud Firestore
//
// Estratégia de controle por papel (role):
// Nesta fase optamos por LER o papel do usuário a partir do próprio documento
// `profiles/{uid}` (campo `role`), em vez de usar Firebase Auth Custom Claims.
// Motivo (ver docs/decisions/ADR-002-auth-strategy.md):
//   - Custom Claims exigem um passo administrativo adicional (Admin SDK) e
//     revogação/atualização do ID Token para refletir mudanças de papel;
//   - Para o MVP, ler `profiles/{uid}.role` é mais simples e suficiente,
//     ao custo de uma leitura extra por regra (aceitável neste volume).
//   - Migração futura para Custom Claims é recomendada quando o número de
//     leituras de regra impactar performance/custo (documentado no ROADMAP).
//
// Princípio: nenhuma regra depende exclusivamente da interface. Toda
// permissão sensível é validada aqui, no servidor de regras do Firestore.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function profileExists() {
      return exists(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn()
        && profileExists()
        && userProfile().role == role;
    }

    function isActiveAccount() {
      return isSignedIn()
        && profileExists()
        && userProfile().status == 'active';
    }

    function isAdmin() {
      return isActiveAccount() && userProfile().role == 'administrator';
    }

    function isReviewer() {
      return isActiveAccount()
        && userProfile().role in ['reviewer', 'administrator'];
    }

    // isContentEditor agora exige TANTO papel editorial QUANTO conta ativa.
    // Uma conta bloqueada ou inativa com papel 'professional' ou 'reviewer'
    // não pode criar, editar nem excluir conteúdos ou categorias via SDK.
    function isContentEditor() {
      return isActiveAccount()
        && userProfile().role in ['professional', 'reviewer', 'administrator'];
    }

    // Campos exclusivamente gravados pelo Admin SDK (publish route e update route).
    // Nenhum cliente deve gravar esses campos diretamente.
    // Nota: reviewedBy NÃO está aqui porque approveKnowledgeItem e rejectKnowledgeItem
    // o escrevem legitimamente pelo SDK do cliente durante transições de revisão.
    // A proteção de reviewedBy é feita separadamente abaixo (apenas isReviewer()).
    function adminOnlyFields() {
      return ['embedding', 'embeddingVersion', 'publishedAt'];
    }

    // Retorna true se a escrita não toca em nenhum campo reservado ao Admin SDK.
    function doesNotTouchAdminFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(adminOnlyFields());
    }

    // reviewedBy só pode ser alterado por revisores/administradores.
    // Um 'professional' não pode autopromover ou manipular quem revisou o item.
    function reviewedByIsUnchangedOrIsReviewer() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reviewedBy'])
        || isReviewer();
    }

    // ------------------------------------------------------------------
    // profiles/{userId}
    // ------------------------------------------------------------------
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Criação: apenas o próprio usuário, e somente com papel/status padrão.
      // Isso impede que alguém se autopromova a administrador no cadastro.
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'family'
        && request.resource.data.status == 'active';

      // Atualização pelo próprio usuário: apenas campos de perfil pessoal.
      // `role` e `status` nunca podem ser alterados pelo próprio usuário.
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
        );

      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // categories/{categoryId}
    // ------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if resource.data.status == 'published' || isContentEditor();
      allow create, update: if isContentEditor();
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // knowledgeItems/{itemId}
    //
    // Máquina de estados de reviewStatus:
    //   draft  ──► in_review  (professional, reviewer, administrator)
    //   in_review ──► draft   (professional, reviewer, administrator)
    //   in_review ──► approved (reviewer, administrator)
    //   approved ──► published (reviewer, administrator) ← via Admin SDK somente
    //   approved ──► rejected  (reviewer, administrator)
    //   published ──► rejected (reviewer, administrator)
    //
    // Proteção de integridade:
    //   - Conteúdo 'published' ou 'approved' só pode ser editado por reviewer/admin.
    //     Um 'professional' não pode alterar texto ou metadados de um item publicado.
    //   - Campos do ciclo de publicação (embedding, embeddingVersion, reviewedBy,
    //     publishedAt) só podem ser escritos pelo Admin SDK — bloqueados aqui via
    //     doesNotTouchAdminFields().
    //   - createdBy é imutável após criação.
    //   - deletedAt só pode ser alterado por administradores.
    // ------------------------------------------------------------------
    match /knowledgeItems/{itemId} {
      // Conteúdo publicado é público; rascunhos/em revisão só para papéis autorizados.
      allow read: if (resource.data.reviewStatus == 'published' && resource.data.deletedAt == null)
        || isContentEditor();

      allow create: if isContentEditor()
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.deletedAt == null
        // Campos de publicação (embedding, embeddingVersion, publishedAt)
        // não podem existir na criação — só o Admin SDK os grava.
        // reviewedBy e version podem ser omitidos (não são inicializados no cliente).
        && !request.resource.data.keys().hasAny(adminOnlyFields());

      allow update: if isContentEditor()
        // 1. Campos de publicação (embedding, embeddingVersion, publishedAt)
        //    são imutáveis pelo cliente SDK — só o Admin SDK os grava.
        && doesNotTouchAdminFields()
        // 2. reviewedBy só pode ser alterado por revisores/administradores
        //    (escrito durante approve/reject — nunca por um professional).
        && reviewedByIsUnchangedOrIsReviewer()
        // 3. createdBy é imutável após criação.
        && (
          !('createdBy' in request.resource.data)
          || request.resource.data.createdBy == resource.data.createdBy
        )
        // 4. Exclusão lógica (deletedAt) é restrita a administradores.
        && (
          request.resource.data.deletedAt == resource.data.deletedAt || isAdmin()
        )
        // 5. Proteção de conteúdo publicado ou aprovado:
        //    apenas reviewer/admin podem editar campos de um item já aprovado ou publicado.
        //    Na prática, edições de publicados passam pela rota /api/admin/knowledge/update
        //    (Admin SDK), que força o retorno a in_review automaticamente.
        && (
          resource.data.reviewStatus in ['draft', 'in_review']
          || isReviewer()
        )
        // 5. Máquina de estados: transições permitidas por papel.
        && (
          // Sem mudança de status: respeita restrição do item 4 acima.
          request.resource.data.reviewStatus == resource.data.reviewStatus
          // draft → in_review: qualquer editor com conta ativa
          || (resource.data.reviewStatus == 'draft' && request.resource.data.reviewStatus == 'in_review')
          // in_review → draft: qualquer editor com conta ativa
          || (resource.data.reviewStatus == 'in_review' && request.resource.data.reviewStatus == 'draft')
          // Transições de revisão: apenas reviewer/admin
          || (
            isReviewer()
            && (
              // in_review → approved
              (resource.data.reviewStatus == 'in_review' && request.resource.data.reviewStatus == 'approved')
              // approved → rejected (rejeição antes de publicar)
              || (resource.data.reviewStatus == 'approved' && request.resource.data.reviewStatus == 'rejected')
              // published → rejected (despublicação)
              || (resource.data.reviewStatus == 'published' && request.resource.data.reviewStatus == 'rejected')
              // Nota: approved → published só ocorre via Admin SDK (publish route)
              // e portanto não aparece aqui — o SDK client não pode gravar 'published'.
            )
          )
        );

      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // knowledgeSources/{sourceId}
    // ------------------------------------------------------------------
    match /knowledgeSources/{sourceId} {
      allow read: if true;
      allow create, update: if isContentEditor();
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // favorites/{userId}/items/{favoriteId}
    //
    // Validação estrutural:
    //   - create: knowledgeItemId (string, não vazia), createdAt (timestamp server)
    //   - update: não permitido (favoritos são imutáveis após criação)
    //   - delete: apenas o dono da conta ativa
    // ------------------------------------------------------------------
    match /favorites/{userId}/items/{favoriteId} {
      allow read: if isOwner(userId) && isActiveAccount();

      allow create: if isOwner(userId)
        && isActiveAccount()
        // knowledgeItemId deve ser uma string não vazia
        && request.resource.data.knowledgeItemId is string
        && request.resource.data.knowledgeItemId.size() > 0
        // createdAt deve ser um timestamp de servidor (não string, não número)
        && request.resource.data.createdAt is timestamp
        // Apenas os campos permitidos — sem campos arbitrários
        && request.resource.data.keys().hasOnly(['knowledgeItemId', 'createdAt']);

      // Favoritos são imutáveis: nenhum campo deve ser alterado após criação.
      allow update: if false;

      allow delete: if isOwner(userId) && isActiveAccount();
    }

    // ------------------------------------------------------------------
    // history/{userId}/items/{historyId}
    //
    // Validação estrutural:
    //   - create: type (em ['search','question','view']), createdAt (timestamp),
    //             query (string ≤ 500), knowledgeItemId (string ou ausente)
    //   - update: não permitido (histórico é imutável)
    //   - delete: apenas o dono da conta ativa
    // ------------------------------------------------------------------
    match /history/{userId}/items/{historyId} {
      allow read: if isOwner(userId) && isActiveAccount();

      allow create: if isOwner(userId)
        && isActiveAccount()
        // type deve ser um dos valores válidos
        && request.resource.data.type in ['search', 'question', 'view']
        // query deve ser string e não pode exceder 500 caracteres
        && request.resource.data.query is string
        && request.resource.data.query.size() <= 500
        // createdAt deve ser um timestamp de servidor
        && request.resource.data.createdAt is timestamp
        // knowledgeItemId, se presente, deve ser string ou null
        // (null indica entrada de busca sem item associado)
        && (
          !('knowledgeItemId' in request.resource.data)
          || request.resource.data.knowledgeItemId == null
          || request.resource.data.knowledgeItemId is string
        )
        // Apenas os campos permitidos — sem campos arbitrários
        && request.resource.data.keys().hasOnly(['type', 'query', 'knowledgeItemId', 'createdAt']);

      // Histórico é imutável após criação.
      allow update: if false;

      allow delete: if isOwner(userId) && isActiveAccount();
    }

    // Bloqueio padrão: qualquer coleção não listada explicitamente é negada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
